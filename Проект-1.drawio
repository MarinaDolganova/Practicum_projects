4px; width: 13px; height: 13px; line-height: 13px; font-size: 8px; border-r=
adius: 50%; background-color: rgb(255, 73, 39); color: rgb(255, 255, 255); =
animation: 1s ease 1s 1 normal both running geZoomAnim; }

@keyframes geBellAnim {=20
  0% { transform: rotate(0deg); }
  10% { transform: rotate(30deg); }
  20% { transform: rotate(0deg); }
  80% { transform: rotate(0deg); }
  90% { transform: rotate(-30deg); }
  100% { transform: rotate(0deg); }
}

@keyframes geRadAnim {=20
  0% { transform: translateX(0px); }
  10% { transform: translateX(5px); }
  20% { transform: translateX(0px); }
  80% { transform: translateX(0px); }
  90% { transform: translateX(-5px); }
  100% { transform: translateX(0px); }
}

@keyframes geZoomAnim {=20
  0% { opacity: 0; transform: scale(0); }
  50% { opacity: 1; transform: scale(1); }
  100% { opacity: 1; }
}

